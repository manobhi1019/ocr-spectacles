<body>
<h1>ESP32 Camera OCR Reader</h1>
<p>Enter ESP32 Camera IP Address</p>
<input id="ipAddress" placeholder="Example: 192.168.1.45">
<button onclick="connectCamera()">Connect Camera</button>
<br><br>
<img id="cameraFeed" width="320">
<canvas id="captureCanvas" width="320" height="240" style="display:none;"></canvas>
<h2>Detected Text</h2>
<p id="output">Waiting for text...</p>

<script>
/* CONNECT TO CAMERA */
function connectCamera(){
let ip = document.getElementById("ipAddress").value;
let cameraURL = "http://" + ip + "/stream";
document.getElementById("cameraFeed").src = cameraURL;
/* start scanning every 3 seconds */
setInterval(scanFrame,3000);
}
/* CAPTURE FRAME AND RUN OCR */
function scanFrame(){
let image = document.getElementById("cameraFeed");
let canvas = document.getElementById("captureCanvas");
let ctx = canvas.getContext("2d");
/* draw frame */
ctx.drawImage(image,0,0,320,240);

/* run OCR */

Tesseract.recognize(canvas,'eng')
.then(function(result){
let detectedText = result.data.text.trim();
if(detectedText.length > 3){
document.getElementById("output").innerText = detectedText;
/* speak text */
let speech = new SpeechSynthesisUtterance(detectedText);
speech.rate = 1;
speechSynthesis.speak(speech);
}
});
}
</script>
</body>
</html>


